#!/usr/bin/env bash

TMUX_SOCKET="/tmp/tmux-1000/default"
CLAUDE_HOME="/home/claude"

# If tmux session already exists, just attach
if tmux -S "$TMUX_SOCKET" has-session -t claude 2>/dev/null; then
  exec tmux -S "$TMUX_SOCKET" attach -t claude
fi

# Check that the OAuth token is available
if [[ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
  echo ""
  echo "ERROR: CLAUDE_CODE_OAUTH_TOKEN is not set."
  echo ""
  echo "To authenticate:"
  echo "  1. Run 'claude setup-token' on your local machine"
  echo "  2. fly secrets set CLAUDE_CODE_OAUTH_TOKEN=<token> -a <app>"
  echo "  3. Restart the machine"
  echo ""
  exit 1
fi

# Write tmux config
cat > /tmp/.tmux.conf <<'TMUX'
set -g status off
set -g remain-on-exit off
set -g history-limit 50000
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",xterm-256color:Tc"
set -g mouse on
set -g allow-passthrough on
set -g aggressive-resize on
set -sg escape-time 0
set -g focus-events on
set -ga terminal-features ",xterm-256color:clipboard:ccolour:cstyle:focus:overline:RGB:strikethrough:title:usstyle"
set -ga terminal-overrides ",*:Smulx=\E[4::%p1%dm"
set -ga terminal-overrides ",*:Setulc=\E[58::2::%p1%{65536}%/%d::%p1%{256}%/%{255}%&%d::%p1%{255}%&%d%;m"
TMUX

# Determine working directory
WORK_DIR="/workspace"
if [[ -d /workspace/repo ]]; then
  WORK_DIR="/workspace/repo"
fi

# Install plugins (first run only)
echo "Installing plugins..."
sudo -u claude \
  HOME="$CLAUDE_HOME" \
  PATH="$CLAUDE_HOME/.local/bin:$CLAUDE_HOME/.bun/bin:$PATH" \
  CLAUDE_CODE_OAUTH_TOKEN="$CLAUDE_CODE_OAUTH_TOKEN" \
  claude plugin install superpowers@claude-plugins-official 2>/dev/null \
  || echo "WARNING: Failed to install superpowers plugin"

# Start Claude Code in tmux as the claude user
sudo -u claude \
  HOME="$CLAUDE_HOME" \
  PATH="$CLAUDE_HOME/.local/bin:$CLAUDE_HOME/.bun/bin:$PATH" \
  GH_CONFIG_DIR="/opt/gh-config" \
  CLAUDE_CODE_OAUTH_TOKEN="$CLAUDE_CODE_OAUTH_TOKEN" \
  TERM="xterm-256color" \
  COLORTERM="truecolor" \
  tmux -f /tmp/.tmux.conf new-session -d -s claude \
    -c "$WORK_DIR" \
    "claude --dangerously-skip-permissions"

# Attach
exec tmux -S "$TMUX_SOCKET" attach -t claude
